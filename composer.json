{
    "name": "dejwcake/testing-kit",
    "description": "Testing utilities and base test cases for Craftable/Laravel projects",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "testing",
        "phpunit",
        "laravel",
        "cms",
        "craftable"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
            "homepage": "https://www.dejw.sk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-dom": "*",
        "ext-libxml": "*",
        "illuminate/support": "^13.0",
        "league/openapi-psr7-validator": "^0.22",
        "mockery/mockery": "^1.6",
        "nyholm/psr7": "^1.8",
        "spatie/phpunit-snapshot-assertions": "^5.4",
        "symfony/psr-http-message-bridge": "^8.0",
        "zircote/swagger-php": "^6.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "DejwCake\\TestingKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DejwCake\\TestingKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "DejwCake\\TestingKit\\TestingKitServiceProvider"
            ]
        }
    }
}
